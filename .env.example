# OpenReels API Keys
# Copy this file to .env and fill in your keys

# Required: LLM provider (at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Required: Text-to-Speech
ELEVENLABS_API_KEY=

# Required: AI Image Generation
GOOGLE_API_KEY=

# Optional: Stock footage (free, but requires registration)
PEXELS_API_KEY=
PIXABAY_API_KEY=
