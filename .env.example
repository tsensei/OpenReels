# OpenReels API Keys
# Copy this file to .env and fill in your keys
#
# Docker: docker run --env-file .env --shm-size=2gb -v ./output:/output openreels "your topic"
# Local:  pnpm start "your topic"

# Required: LLM provider (at least one)
# Anthropic (default): https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI (--provider openai): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required: Text-to-Speech (at least one)
# ElevenLabs (default): https://elevenlabs.io/
ELEVENLABS_API_KEY=
# Inworld (--tts-provider inworld): https://inworld.ai/
INWORLD_TTS_API_KEY=

# Required: AI Image Generation (at least one)
# Gemini (default): https://aistudio.google.com/apikey
# OpenAI GPT Image (--image-provider openai): uses OPENAI_API_KEY above
GOOGLE_API_KEY=

# Optional: Stock footage (free, but requires registration)
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=
# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=
